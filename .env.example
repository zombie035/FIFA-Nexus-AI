# FIFA Nexus AI - Environment Configuration
# Copy this file to .env and fill in the actual values
# Never commit the actual .env file — it is in .gitignore

# ─── AI Model Configuration ──────────────────────────────────────────────────
# Google Gemini API Key (get one free at https://aistudio.google.com/apikey)
# If not provided, the AI Copilot will run in intelligent simulation mode
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database Configuration ───────────────────────────────────────────────────
# PostgreSQL connection (pre-configured in docker-compose.yml)
DATABASE_URL=postgresql://postgres:password@postgres:5432/fifanexus

# ─── Redis Configuration ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Frontend Environment Variables ──────────────────────────────────────────
# These are consumed by the Next.js frontend (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Optional: Application Settings ─────────────────────────────────────────
# Simulation speed (ms delay between streaming tokens in fallback mode)
AI_STREAM_DELAY_MS=40

# Default role for unauthenticated users
DEFAULT_ROLE=Fan
